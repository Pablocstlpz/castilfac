# =============================================================================
# .env.example - backend Castilfac (ejecucion local sin Docker)
# Copia este archivo a `.env` y rellena los valores:
#   cp .env.example .env
# Si usas docker-compose desde la raiz, las variables vienen del .env raiz
# y NO necesitas este archivo.
# =============================================================================

PORT=3000

# Base de datos local
DB_HOST=localhost
DB_PORT=3306
DB_USER=castilfac
DB_PASSWORD=cambia-esta-clave
DB_DATABASE=castilfac

# URLs publicas
URL=http://localhost:3000
FRONTEND_URL=http://localhost:4200

# JWT (generar con `openssl rand -hex 64`)
SECRET_KEY=reemplaza-con-cadena-aleatoria-larga
REFRESH_SECRET_KEY=reemplaza-con-otra-cadena-aleatoria-larga

# Login con Google
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com

# Envio de correos (SMTP Gmail con contrasena de aplicacion)
EMAIL_USER=tu-cuenta@gmail.com
EMAIL_PASS=app-password-de-gmail

# Stripe
STRIPE_SECRET_KEY=<tu-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<tu-stripe-webhook-secret>
