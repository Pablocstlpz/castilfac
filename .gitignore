# =============================================================================
# .gitignore raiz - Castilfac (backend Node/Express + frontend Angular + Docker)
# =============================================================================

# -----------------------------------------------------------------------------
# Secretos y configuracion local  (CRITICO: nunca subir nada de esto)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# -----------------------------------------------------------------------------
# Dependencias
# -----------------------------------------------------------------------------
node_modules/
backend/node_modules/
frontend/node_modules/
.pnp
.pnp.js
jspm_packages/

# -----------------------------------------------------------------------------
# Build / output
# -----------------------------------------------------------------------------
# Angular
frontend/dist/
frontend/tmp/
frontend/out-tsc/
frontend/bazel-out/
/dist
/tmp
/out-tsc
/bazel-out

# Backend (si en el futuro hay build paso)
backend/dist/
backend/build/

# -----------------------------------------------------------------------------
# Cache de Angular y herramientas
# -----------------------------------------------------------------------------
.angular/
frontend/.angular/cache/
.sass-cache/
.eslintcache
.parcel-cache/
.cache/
.turbo/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm/

# -----------------------------------------------------------------------------
# Coverage / tests
# -----------------------------------------------------------------------------
coverage/
*.lcov
.nyc_output/
__screenshots__/
testem.log
/libpeerconnection.log

# -----------------------------------------------------------------------------
# IDEs y editores
# -----------------------------------------------------------------------------
# VS Code: ignoramos casi todo, pero permitimos compartir 4 ficheros utiles
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/

# JetBrains
.idea/
*.iml
*.iws
*.ipr

# Eclipse / otros
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project

# Vim
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Sistema operativo
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Los compose y Dockerfiles SI se versionan; ignoramos solo overrides locales.
docker-compose.override.yml
docker-compose.local.yml
.docker/

# -----------------------------------------------------------------------------
# Datos locales / dumps SQL (no queremos subir BDs con datos)
# -----------------------------------------------------------------------------
*.sql.gz
*.sqlite
*.sqlite3
*.db
db_dumps/
mysql_data/
mariadb_data/

# -----------------------------------------------------------------------------
# Subidas de usuarios / archivos generados
# -----------------------------------------------------------------------------
uploads/
backend/uploads/
backend/tmp/

# -----------------------------------------------------------------------------
# Herramientas locales (Claude Code, etc.)
# -----------------------------------------------------------------------------
.claude/
.cursor/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
/connect.lock
/typings
.serverless/
.fusebox/
.dynamodb/
*.tsbuildinfo
