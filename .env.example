# =============================================================================
# .env.example - Castilfac
# Copia este archivo a `.env` en la raiz del proyecto y rellena los valores.
#   cp .env.example .env
# Docker Compose leera automaticamente las variables ${NOMBRE} desde aqui.
# NUNCA subas el .env real al repositorio (esta ignorado en .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Puertos publicados en el host
# -----------------------------------------------------------------------------
BACKEND_PORT=3000
FRONTEND_PORT=8080

# -----------------------------------------------------------------------------
# Base de datos (MariaDB)
# El host dentro de la red de Docker es "mariadb" (nombre del servicio).
# DB_PASSWORD se usa tambien como MARIADB_ROOT_PASSWORD.
# -----------------------------------------------------------------------------
DB_USER=castilfac
DB_PASSWORD=cambia-esta-clave
DB_DATABASE=castilfac

# -----------------------------------------------------------------------------
# URLs publicas de la aplicacion
# En desarrollo local pueden ser http://localhost:<puerto>.
# -----------------------------------------------------------------------------
URL=https://api.tu-dominio.com
FRONTEND_URL=https://tu-dominio.com

# -----------------------------------------------------------------------------
# JWT
# Generar valores aleatorios largos (p.ej. `openssl rand -hex 64`).
# -----------------------------------------------------------------------------
SECRET_KEY=reemplaza-con-cadena-aleatoria-larga
REFRESH_SECRET_KEY=reemplaza-con-otra-cadena-aleatoria-larga

# -----------------------------------------------------------------------------
# Login con Google (OAuth)
# Obtener en https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com

# -----------------------------------------------------------------------------
# Envio de correos (SMTP Gmail con contrasena de aplicacion)
# -----------------------------------------------------------------------------
EMAIL_USER=tu-cuenta@gmail.com
EMAIL_PASS=app-password-de-gmail

# -----------------------------------------------------------------------------
# Stripe (pagos)
# Claves en https://dashboard.stripe.com/apikeys
# El webhook secret se genera al configurar el endpoint de webhooks.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=<tu-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<tu-stripe-webhook-secret>
